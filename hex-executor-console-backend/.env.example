# Neo Local Operator API — copy to `.env` (gitignored) and adjust.
# Standard startup: `npm run start` / `npm run dev` use scripts/runWithNeoEnv.mjs
# which runs `node --env-file=.env` when `.env` exists (Gemini keys visible at module load).

PORT=3847
NEO_WORKSPACE_ROOT=

# Android / emulator (default target — see docs/OPERATING-CONSTITUTION.md)
ANDROID_HOME=
NEO_MYPHONECHECK_AVD=
# Physical handset UX exception only (not the default route)
# NEO_UX_EXCEPTION_PHYSICAL_DEVICE=1
# myphonecheck_app_launch 워크플로용 앱 패키지명 (예: com.example.app)
NEO_MYPHONECHECK_PACKAGE=

# AI providers (optional — without keys, command classification falls back to deterministic rules)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
# auto | gemini | ollama
AI_PROVIDER_MODE=auto

# LLM workflow planner (MyPhoneCheck capture 등) — gemini | ollama | claude
PLANNER_MODEL_KIND=gemini
# 플래너 전용 모델명 (미설정 시: Gemini면 GEMINI_MODEL, Ollama면 OLLAMA_MODEL)
# PLANNER_MODEL_NAME=

# 0 이면 항상 정적 DAG (NEO_LLM_PLANNER_ENABLED=0)
# NEO_LLM_PLANNER_ENABLED=1
# 1 이면 플래너 프롬프트/응답 일부 로그 (NEO_PLANNER_DEV_LOG=1)
# NEO_PLANNER_DEV_LOG=

# 1 이면 POST /api/command/parse-debug 활성화 (개발용)
# NEO_PARSE_DEBUG=1
